<section id="hero" class="relative h-screen pt-16 overflow-hidden">
  <div
    id="hero-bg"
    class="absolute inset-0 bg-[url('/images/hero/hero-temata.jpg')] bg-cover bg-[center_30%] will-change-transform"
    style="transform: scale(1.2) translateY(0)"
  ></div>
  <div class="absolute inset-0 bg-black/0 z-10"></div>

  <div class="relative z-20 mx-auto flex h-screen items-center justify-center px-4 py-4 text-center">
    <div class="max-w-xl sm:max-w-2xl rounded-xl bg-black/60 p-4 text-white backdrop-blur-sm sm:p-8">
      <h1 class="text-3xl font-medium leading-tight sm:text-5xl [text-shadow:0_1px_4px_rgba(0,0,0,0.6)]">We're here to help</h1>
      <p class="mt-3 text-base leading-relaxed text-[#f5f4f0] sm:mt-5 sm:text-lg [text-shadow:0_1px_3px_rgba(0,0,0,0.5)]">
        Full range ear, nose, throat, neck and facial skin surgery in Hawke's Bay with direct 24/7 post-operative access to your surgeon.
      </p>
      <a id="hero-cta" href="#request" class="mt-4 inline-block rounded-full bg-forest-green px-8 py-3 text-sm font-medium text-white shadow-lg transition hover:bg-[#244f3e] focus:outline-none focus:ring-2 focus:ring-green-tint sm:mt-6">
        Request a consultation
      </a>
    </div>
  </div>
</section>

<script>
  const bg = document.getElementById('hero-bg');
  if (bg) {
    const hero = bg.parentElement;
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      if (scrolled <= hero.offsetHeight) {
        bg.style.transform = `scale(1.2) translateY(${scrolled * 0.25}px)`;
      }
    }, { passive: true });
  }
</script>
