            <span class="mb-1 block text-sm font-medium text-near-black">Name</span>
            <input type="text" name="name" placeholder="Your name" class="w-full rounded border border-border bg-white px-3 py-2 text-sm text-near-black focus:border-forest-green focus:outline-none" />
