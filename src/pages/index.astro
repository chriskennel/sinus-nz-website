---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
---
<BaseLayout>
  <Nav />

  <main class="pt-16">
    <Hero />
    <TrustBar />

    <section id="conditions" class="bg-off-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-5 text-2xl font-medium text-near-black">What we treat</h2>
        <p class="mb-6 text-muted-text">Select one to jump to the section below.</p>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <a href="#ears" class="overflow-hidden rounded-xl border border-border bg-white transition hover:border-forest-green hover:shadow-lg">
            <img src="/images/conditions/ear%20smooth.jpg" alt="" class="h-48 w-full object-cover" />
            <div class="p-4">
              <h3 class="text-lg font-medium text-near-black">Ears</h3>
              <p class="text-sm text-muted-text">Complex ear surgery, hearing loss, Osia implants.</p>
            </div>
          </a>
          <a href="#head-neck" class="overflow-hidden rounded-xl border border-border bg-white transition hover:border-forest-green hover:shadow-lg">
            <img src="/images/conditions/neck%20smooth.jpg" alt="" class="h-48 w-full object-cover" />
            <div class="p-4">
              <h3 class="text-lg font-medium text-near-black">Head & neck & skin</h3>
              <p class="text-sm text-muted-text">Skin lesions, neck masses, parotid surgery, cancer care.</p>
            </div>
          </a>
          <a href="#nose" class="overflow-hidden rounded-xl border border-border bg-white transition hover:border-forest-green hover:shadow-lg">
            <img src="/images/conditions/nose%20smooth.jpg" alt="" class="h-48 w-full object-cover object-[center_75%]" />
            <div class="p-4">
              <h3 class="text-lg font-medium text-near-black">Nose & sinuses</h3>
              <p class="text-sm text-muted-text">Sinusitis, polyps, allergies, coblation tonsillectomy.</p>
            </div>
          </a>
          <a href="#throat" class="overflow-hidden rounded-xl border border-border bg-white transition hover:border-forest-green hover:shadow-lg">
            <img src="/images/conditions/throat%20smooth.jpg" alt="" class="h-48 w-full object-cover" />
            <div class="p-4">
              <h3 class="text-lg font-medium text-near-black">Throat</h3>
              <p class="text-sm text-muted-text">Tonsils, adenoids, swallowing disorders.</p>
            </div>
          </a>
        </div>
      </div>
    </section>
    <section id="ears" class="bg-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">Ears</h2>
        <p class="mb-8 text-muted-text">
          Specialized care for ear conditions, including complex microsurgery and advanced hearing solutions.
        </p>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="cholesteatoma" type="checkbox" class="peer sr-only" />
            <label for="cholesteatoma" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Cholesteatoma</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Abnormal skin growth in the middle ear causing erosion of bone, infections and hearing loss. Requires surgical removal to prevent complications and reconstruction to restore hearing.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="osia-implant" type="checkbox" class="peer sr-only" />
            <label for="osia-implant" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Osia implanted hearing device</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Advanced bone conduction implant for severe hearing loss. Surgically placed behind the ear for improved hearing. Dr. Kennel was one of the first surgeons in New Zealand to have implanted this device.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="surfers-ear" type="checkbox" class="peer sr-only" />
            <label for="surfers-ear" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Surfer's ear — minimally invasive canalplasty</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Bony growths in the ear canal from cold water exposure cause recurrent infections and hearing loss. Dr. Kennel performs minimally invasive canalplasty to remove the growths with less pain and faster recovery than traditional approaches.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="otosclerosis" type="checkbox" class="peer sr-only" />
            <label for="otosclerosis" class="cursor-pointer font-normal text-near-black">
              Otosclerosis & congenital stapes fixation
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Abnormal bone growth in the middle ear causing conductive hearing loss. Treated with stapes surgery to restore hearing.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="eardrum-perforation" type="checkbox" class="peer sr-only" />
            <label for="eardrum-perforation" class="cursor-pointer font-normal text-near-black">
              Perforated eardrum repair
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              A hole in the eardrum from infection, trauma, or pressure changes can cause hearing loss and recurrent infections. Myringoplasty and tympanoplasty close the perforation to restore hearing and protect the middle ear.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="hearing-loss" type="checkbox" class="peer sr-only" />
            <label for="hearing-loss" class="cursor-pointer font-normal text-near-black">
              Hearing loss / grommets
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Middle ear fluid causing conductive hearing loss. Often treated with grommet tubes to drain fluid and restore hearing. This can be done in clinic under local anaesthetic for adults. Children usually require general anaesthetic.
            </div>
          </div>
        </div>
      </div>
    </section>
    <section id="nose" class="bg-off-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <div class="mb-6 flex items-center gap-3">
          <h2 class="text-2xl font-medium text-near-black">Nose & sinuses</h2>
        </div>
        <p class="mb-8 text-muted-text">
          Comprehensive care for nasal and sinus conditions, including advanced endoscopic surgery.
        </p>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="chronic-sinusitis" type="checkbox" class="peer sr-only" />
            <label for="chronic-sinusitis" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Chronic sinusitis</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Chronic inflammation of the sinuses causing congestion, facial pain, and recurrent infections. Treated with medical therapy and endoscopic sinus surgery when needed.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="nasal-polyps" type="checkbox" class="peer sr-only" />
            <label for="nasal-polyps" class="cursor-pointer font-normal text-near-black">
              Nasal polyps
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Non-cancerous growths in the nasal passages causing obstruction and loss of smell. Often associated with chronic sinusitis and allergies.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="adenoidectomy" type="checkbox" class="peer sr-only" />
            <label for="adenoidectomy" class="cursor-pointer font-normal text-near-black">
              Adenoidectomy
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Surgical removal of enlarged adenoids that can cause nasal obstruction, snoring, and recurrent ear infections in children.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="blocked-nose" type="checkbox" class="peer sr-only" />
            <label for="blocked-nose" class="cursor-pointer font-normal text-near-black">
              Blocked nose / deviated nasal septum
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Nasal obstruction due to a deviated septum or enlarged turbinates. Can be corrected with septoplasty or turbinate reduction surgery. Dr. Kennel uses coblation technology for turbinate reduction, which causes less bleeding and faster recovery than traditional techniques.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="allergy-rhinitis" type="checkbox" class="peer sr-only" />
            <label for="allergy-rhinitis" class="cursor-pointer font-normal text-near-black">
              Allergy & rhinitis (inhalational)
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Allergic rhinitis caused by airborne allergens like pollen, dust, and pet dander. Managed with medications and immunotherapy when appropriate.
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="head-neck" class="bg-white border-b border-border py-10">

      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">Head & neck & skin</h2>
        <p class="mb-8 text-muted-text">
          Comprehensive care for head, neck, and skin conditions, including cancer treatment and reconstructive surgery.
        </p>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="parotid-surgery" type="checkbox" class="peer sr-only" />
            <label for="parotid-surgery" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Parotid tumour surgery</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Dr. Kennel removes parotid tumours through a minimal facelift incision, concealing the scar within natural skin folds. Fat grafting is used to restore the facial contour, reducing the visible indentation that often follows traditional parotidectomy. Facial nerve preservation is a priority — to date, no patient has sustained a permanent facial nerve injury from parotid surgery at ENT &amp; Allergy.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="zenkers-diverticulum" type="checkbox" class="peer sr-only" />
            <label for="zenkers-diverticulum" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Zenker's diverticulum & cricopharyngeal dysfunction</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Zenker's diverticulum is treated with minimally invasive transoral surgery using specialised equipment — less pain and faster recovery than open approaches. Cricopharyngeal dysfunction causing swallowing difficulty is treated with open cricopharyngeal myotomy when conservative measures have failed.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="head-neck-cancer" type="checkbox" class="peer sr-only" />
            <label for="head-neck-cancer" class="cursor-pointer font-normal text-near-black">
              Head & neck cancer
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Surgical treatment for head and neck cancers including oral, oropharyngeal, and salivary gland malignancies, with neck dissection where required. Neck dissection for melanoma and metastatic cutaneous SCC also performed. Cases needing laryngectomy or major reconstructive surgery are referred to specialist centres in Auckland or Wellington.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="facial-skin-lesions" type="checkbox" class="peer sr-only" />
            <label for="facial-skin-lesions" class="cursor-pointer font-normal text-near-black">
              Facial skin lesions & skin cancer
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Surgical removal of benign and malignant skin lesions of the face, scalp, and neck — from cysts and benign growths to BCC, SCC, and melanoma. Includes reconstruction to restore appearance and function. Where cancer has spread to regional lymph nodes, neck dissection can be performed locally.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-off-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="neck-masses" type="checkbox" class="peer sr-only" />
            <label for="neck-masses" class="cursor-pointer font-normal text-near-black">
              Neck masses
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Lumps or swellings in the neck can have many causes — benign cysts, lymph node enlargement, or tumours requiring urgent assessment. Ultrasound-guided fine needle aspiration (FNA) is available in clinic to speed diagnosis, avoiding a separate radiology referral.
            </div>
          </div>

        </div>
      </div>
    </section>

    <section id="throat" class="bg-off-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">Throat</h2>
        <p class="mb-8 text-muted-text">
          Surgical care for throat conditions, including tonsils, adenoids, and swallowing disorders.
        </p>

        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="coblation-tonsillectomy" type="checkbox" class="peer sr-only" />
            <label for="coblation-tonsillectomy" class="flex cursor-pointer items-center justify-between">
              <span class="font-normal text-near-black">Coblation tonsillectomy</span>
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Dr. Kennel was the first surgeon in the region to offer coblation intracapsular tonsillectomy. Less tissue damage means less pain and faster recovery than traditional methods — and his audit shows 0% readmission for bleeding, pain, or dehydration in coblation cases.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="tonsils-adenoids" type="checkbox" class="peer sr-only" />
            <label for="tonsils-adenoids" class="cursor-pointer font-normal text-near-black">
              Tonsils & adenoids
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Surgical treatment for recurrent infections, obstruction, or sleep apnoea. Includes traditional and coblation techniques.
            </div>
          </div>

          <div class="rounded-lg border border-border bg-white p-4 transition hover:border-forest-green hover:shadow-sm">
            <input id="botox-cricopharyngeal" type="checkbox" class="peer sr-only" />
            <label for="botox-cricopharyngeal" class="cursor-pointer font-normal text-near-black">
              Botox for retrograde cricopharyngeal dysfunction
            </label>
            <div class="mt-3 hidden text-sm text-muted-text peer-checked:block">
              Retrograde cricopharyngeal dysfunction (R-CPD) prevents normal belching and can cause bloating, gurgling, and social distress. Botox injection into the cricopharyngeal muscle is a highly effective, minimally invasive treatment.
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="how" class="bg-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">What to expect</h2>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="rounded-xl border border-border bg-off-white p-5 transition hover:shadow-sm">
            <a href="#request" class="group">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-forest-green text-white transition group-hover:bg-[#244f3e]">
                <span class="font-bold">1</span>
              </div>
              <h3 class="mb-1 font-medium text-near-black transition group-hover:text-forest-green">Request a consultation</h3>
            </a>
            <p class="text-sm text-muted-text">Contact us by <a href="tel:+6466514070" class="text-forest-green hover:underline">phone</a> or <a href="#request" class="text-forest-green hover:underline">online form</a>. Self-referrals and GP referrals both welcome.</p>
          </div>
          <div class="rounded-xl border border-border bg-off-white p-5 transition hover:shadow-sm">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-forest-green text-white">
              <span class="font-bold">2</span>
            </div>
            <h3 class="mb-1 font-medium text-near-black">Initial appointment</h3>
            <p class="text-sm text-muted-text">A thorough examination and diagnosis. Endoscopy and minor procedures are often performed. Imaging or blood tests may also be ordered.</p>
          </div>
          <div class="rounded-xl border border-border bg-off-white p-5 transition hover:shadow-sm">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-forest-green text-white">
              <span class="font-bold">3</span>
            </div>
            <h3 class="mb-1 font-medium text-near-black">Results review</h3>
            <p class="text-sm text-muted-text">If investigations were needed, a follow-up to review results and confirm your treatment plan.</p>
          </div>
          <div class="rounded-xl border border-border bg-off-white p-5 transition hover:shadow-sm">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-forest-green text-white">
              <span class="font-bold">4</span>
            </div>
            <h3 class="mb-1 font-medium text-near-black">Treatment</h3>
            <p class="text-sm text-muted-text">Prompt and definitive. Dr. Kennel aims to avoid unnecessary follow-ups — most patients move to treatment without delay.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="bg-off-white border-b border-border py-10">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 md:flex-row md:items-center md:justify-between md:px-6">
        <div class="md:w-1/2">
          <h2 class="mb-3 text-2xl font-medium text-near-black">About Dr. Chris Kennel</h2>
          <p class="mb-4 text-muted-text">
            Dr. Kennel is a fellowship-trained otolaryngologist who moved from the US to Hawke's Bay in 2022 with his family — drawn by the lifestyle, the community, and the opportunity to provide comprehensive ENT care in a region that needs it.
          </p>
          <p class="mb-4 text-muted-text">
            Originally from Colorado, he completed his medical training at the University of Colorado School of Medicine and otolaryngology residency at the University of Missouri School of Medicine, followed by an advanced fellowship in complex ear surgery, neurotology, and stereotactic radiosurgery in Delaware, and a fellowship with the American Academy of Otolaryngic Allergy.
          </p>
          <p class="mb-4 text-muted-text">
            He is a Diplomate of the American Board of Otolaryngology — Head & Neck Surgery, a Fellow of the Royal Australasian College of Surgeons (FRACS), and holds vocational registration as a specialist with the Medical Council of New Zealand. He also teaches ENT registrars through the public hospital system.
          </p>
          <p class="text-muted-text">
            Having navigated significant health challenges within his own family, he knows first-hand how important it is to be able to reach your surgeon directly — and gives his mobile number to all surgical patients for that reason.
          </p>
        </div>
        <div class="md:w-1/2">
          <img src="/images/dr-kennel/dr-kennel.jpg" alt="Dr. Chris Kennel" class="w-full rounded-lg object-cover" />
        </div>
      </div>
    </section>
    <section id="unique" class="bg-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">Why choose ENT & Allergy?</h2>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Full range of ENT and head & neck surgery — most patients treated locally, without needing to travel to Auckland or Wellington</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Fellow of the Royal Australasian College of Surgeons (FRACS) — the highest surgical qualification in Australasia</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">24/7 post-operative access to your surgeon</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">On-call, after-hours emergency care</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Treats both public and private patients</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Treats all ages, from young children to adults</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Minimally invasive surgical techniques for faster recovery</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Nerve blocks and Botox for ENT-specific pain</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Self-referrals and GP referrals both welcome</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Easy-to-understand written summary after every visit</p>
          </div>
          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Annual surgical outcome audit — one of the few ENT surgeons in New Zealand to publish complication rates</p>
          </div>


          <div class="rounded-lg border border-border bg-off-white px-4 py-3 transition hover:shadow-sm">
            <p class="text-sm text-near-black">Contract surgeon for Health New Zealand — trusted by the public hospital system for specialist ENT care</p>
          </div>
        </div>
      </div>
    </section>

    <section id="location" class="bg-off-white border-b border-border py-10">
      <div class="mx-auto max-w-6xl px-4 md:px-6">
        <h2 class="mb-6 text-2xl font-medium text-near-black">Our location</h2>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
          <div>
            <h3 class="mb-3 text-lg font-medium text-near-black">Kaweka Specialist Centre</h3>
            <p class="mb-4 text-muted-text">Level 2, Kaweka Specialist Centre<br />209 Canning Road<br />Hastings, Hawke's Bay<br />New Zealand</p>
            <p class="mb-4 text-muted-text">
              <strong>Phone:</strong> <a href="tel:+6466514070" class="text-forest-green hover:underline">06 651 4070</a><br />
              <strong>Hours:</strong> Monday–Friday 8:30 AM – 4:30 PM
            </p>
            <a href="https://www.google.com/maps/dir/?api=1&destination=209+Canning+Road+Hastings+Hawke's+Bay+New+Zealand" target="_blank" class="inline-flex items-center rounded-full bg-forest-green px-6 py-3 text-sm font-medium text-white transition hover:bg-[#244f3e]">
              Get directions
            </a>
          </div>
          <div class="w-full overflow-hidden rounded-lg">
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3073.000255167667!2d176.81742476623816!3d-39.6271980983495!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d69cb007987d483%3A0xa6b653ad79c44b54!2sKaweka%20Specialist%20Centre!5e0!3m2!1sen!2snz!4v1775168112593!5m2!1sen!2snz" width="100%" height="300" style="border:0; display:block;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
