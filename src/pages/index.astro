          <label>
            <span class="mb-1 block text-sm font-medium text-near-black">Email address</span>
            <input type="email" name="email" placeholder="you@example.com" class="w-full rounded border border-border bg-white px-3 py-2 text-sm text-near-black focus:border-forest-green focus:outline-none" />
          </label>
          <label>
            <span class="mb-1 block text-sm font-medium text-near-black">Phone number</span>
            <input type="tel" name="phone" placeholder="06 651 4070" class="w-full rounded border border-border bg-white px-3 py-2 text-sm text-near-black focus:border-forest-green focus:outline-none" />
          </label>
          <label class="sm:col-span-2">
            <span class="mb-1 block text-sm font-medium text-near-black">Reason for consultation</span>
            <textarea name="reason" rows="4" placeholder="Tell us briefly what you're experiencing" class="w-full rounded border border-border bg-white px-3 py-2 text-sm text-near-black focus:border-forest-green focus:outline-none"></textarea>
          </label>
          <button type="submit" class="sm:col-span-2 inline-flex items-center justify-center rounded-full bg-forest-green px-6 py-3 text-sm font-medium text-white transition hover:bg-[#244f3e]">
            Submit request
          </button>
        </form>

      </div>
    </section>

  </main>

