---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Referral received | ENT & Allergy">
  <div class="flex min-h-screen items-center justify-center px-4 text-center">
    <div class="max-w-md">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-forest-green text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <h1 class="mb-3 text-2xl font-medium text-near-black">Referral received</h1>
      <p class="mb-3 text-muted-text">Thank you — we will contact the patient directly to arrange their appointment.</p>
      <p class="mb-8 text-muted-text text-sm">If we need any additional clinical information before the consultation, we'll be in touch with you.</p>
      <a href="/" class="inline-block rounded-full bg-forest-green px-8 py-3 text-sm font-medium text-white transition hover:bg-[#244f3e]">Back to home</a>
    </div>
  </div>
</BaseLayout>
