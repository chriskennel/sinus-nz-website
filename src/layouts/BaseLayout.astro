---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Dr. Chris Kennel FRACS — sinus surgery, septoplasty, advanced ear surgery & head & neck cancer specialist in Hastings, Hawke's Bay. Coblation tonsillectomy, stapes, parotid surgery. Self-referrals welcome." />
    <title>{title}</title>
    <link rel="canonical" href="https://entallergy.nz/" />
    <!-- Open Graph / social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://entallergy.nz/" />
    <meta property="og:title" content="ENT & Allergy | Ear, Nose & Throat Specialist | Hawke's Bay" />
    <meta property="og:description" content="Dr. Chris Kennel FRACS — sinus surgery, septoplasty, advanced ear surgery & head & neck cancer specialist in Hastings, Hawke's Bay. Coblation tonsillectomy, stapes, parotid surgery. Self-referrals welcome." />
    <meta property="og:image" content="https://entallergy.nz/images/dr-kennel/dr-kennel.jpg" />
    <meta property="og:image:width" content="800" />
    <meta property="og:image:height" content="1000" />
    <meta property="og:image:alt" content="Dr. Chris Kennel, ENT & Allergy surgeon in Hawke's Bay" />
    <meta name="msvalidate.01" content="3D5C1B48B041F0C6FD731154E43259A4" />
    <link rel="icon" href="/images/logo/favicon.png" type="image/png" />
    <link rel="preload" as="image" href="/images/hero/hero-temata.jpg" fetchpriority="high" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Load Google Fonts non-blocking -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Gotu&family=DM+Sans:wght@400;500&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Gotu&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Gotu&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" /></noscript>

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": ["Physician", "MedicalBusiness"],
      "@id": "https://entallergy.nz/",
      "name": "ENT & Allergy",
      "url": "https://entallergy.nz/",
      "telephone": "+6466514070",
      "image": "https://entallergy.nz/images/logo/favicon.png",
      "description": "Dr. Chris Kennel FRACS — fellowship-trained ENT surgeon offering advanced ear, sinus, head & neck, and allergy care in Hastings, Hawke's Bay. Self-referrals welcome.",
      "medicalSpecialty": "Otolaryngologic",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Level 2, Kaweka Specialist Centre, 209 Canning Road",
        "addressLocality": "Hastings",
        "addressRegion": "Hawke's Bay",
        "postalCode": "4120",
        "addressCountry": "NZ"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:30",
          "closes": "16:30"
        }
      ],
      "areaServed": [
        { "@type": "AdministrativeArea", "name": "Hawke's Bay" },
        { "@type": "AdministrativeArea", "name": "Gisborne / Tairāwhiti" }
      ],
      "availableService": [
        { "@type": "MedicalProcedure", "name": "Stapedectomy (stapes surgery)" },
        { "@type": "MedicalProcedure", "name": "Coblation tonsillectomy" },
        { "@type": "MedicalProcedure", "name": "Mastoidectomy" },
        { "@type": "MedicalProcedure", "name": "Functional endoscopic sinus surgery (FESS)" },
        { "@type": "MedicalProcedure", "name": "Septoplasty" },
        { "@type": "MedicalProcedure", "name": "Turbinate reduction" },
        { "@type": "MedicalProcedure", "name": "Tympanoplasty / myringoplasty" },
        { "@type": "MedicalProcedure", "name": "Cholesteatoma surgery" },
        { "@type": "MedicalProcedure", "name": "Canalplasty (surfer's ear surgery)" },
        { "@type": "MedicalProcedure", "name": "Osia implant / bone anchored hearing device" },
        { "@type": "MedicalProcedure", "name": "Parotid surgery (facelift approach)" },
        { "@type": "MedicalProcedure", "name": "Transoral Zenker's diverticulum surgery" },
        { "@type": "MedicalProcedure", "name": "SPA ligation for epistaxis" },
        { "@type": "MedicalProcedure", "name": "Skin cancer surgery and facial reconstruction" },
        { "@type": "MedicalProcedure", "name": "Grommets / ventilation tube insertion" },
        { "@type": "MedicalProcedure", "name": "Adenotonsillectomy" },
        { "@type": "MedicalProcedure", "name": "Neck dissection" },
        { "@type": "MedicalProcedure", "name": "Head and neck cancer surgery" },
        { "@type": "MedicalProcedure", "name": "Ultrasound-guided fine needle aspiration (FNA) biopsy" },
        { "@type": "MedicalProcedure", "name": "Nasal cautery" },
        { "@type": "MedicalProcedure", "name": "Nasal endoscopy" },
        { "@type": "MedicalProcedure", "name": "Flexible laryngoscopy" },
        { "@type": "MedicalProcedure", "name": "Ear microsuction" },
        { "@type": "MedicalProcedure", "name": "Allergy skin testing" },
        { "@type": "MedicalProcedure", "name": "Audiometry and tympanometry" }
      ],
      "physician": {
        "@type": "Physician",
        "name": "Dr. Chris Kennel",
        "honorificPrefix": "Dr.",
        "honorificSuffix": "FRACS",
        "jobTitle": "Otolaryngologist — Head & Neck Surgeon",
        "description": "Fellowship-trained ENT surgeon. Fellow of the Royal Australasian College of Surgeons (FRACS), Diplomate of the American Board of Otolaryngology — Head & Neck Surgery. Advanced fellowship in otology and neurotology.",
        "medicalSpecialty": "Otolaryngologic",
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Fellow of the Royal Australasian College of Surgeons",
            "abbreviation": "FRACS",
            "credentialCategory": "fellowship"
          },
          {
            "@type": "EducationalOccupationalCredential",
            "name": "Diplomate of the American Board of Otolaryngology — Head & Neck Surgery",
            "credentialCategory": "board certification"
          }
        ],
        "alumniOf": [
          { "@type": "EducationalOrganization", "name": "University of Colorado School of Medicine" },
          { "@type": "EducationalOrganization", "name": "University of Missouri School of Medicine" }
        ],
        "knowsAbout": [
          "Stapedectomy", "Stapes surgery", "Mastoidectomy",
          "Coblation tonsillectomy", "Adenotonsillectomy",
          "Functional endoscopic sinus surgery", "FESS",
          "Septoplasty", "Turbinate reduction",
          "Tympanoplasty", "Myringoplasty",
          "Cholesteatoma surgery", "Canalplasty", "Surfer's ear surgery",
          "Osia implant", "Bone anchored hearing aid", "BAHA",
          "Parotid surgery", "Transoral Zenker's diverticulum surgery",
          "SPA ligation", "Epistaxis surgery",
          "Skin cancer surgery", "Facial reconstruction", "Flap and graft surgery",
          "Grommets", "Ventilation tubes",
          "Head and neck cancer surgery", "Neck dissection",
          "Ultrasound-guided fine needle aspiration", "FNA biopsy",
          "Nasal endoscopy", "Flexible laryngoscopy", "Nasal cautery", "Ear microsuction",
          "Otology", "Neurotology", "Rhinology", "Head and neck surgery", "Otolaryngology",
          "Cholesteatoma", "Chronic sinusitis", "Nasal polyps", "Deviated septum",
          "Otosclerosis", "Head and neck cancer", "Skin cancer", "BCC", "SCC",
          "Allergic rhinitis", "Recurrent epistaxis", "Swallowing difficulty", "Glue ear",
          "Perforated eardrum", "Hearing loss", "Surfer's ear"
        ]
      }
    }
    </script>
  </head>
  <body class="bg-off-white text-near-black antialiased">
    <style is:global>
      body {
        font-family: 'DM Sans', system-ui, sans-serif;
      }
      h1, h2, h3 {
        font-family: 'Gotu', system-ui, sans-serif;
        font-weight: 400;
      }
      section[id] {
        scroll-margin-top: 64px;
      }
    </style>
    <slot />

    <!-- Sticky CTA for mobile and desktop -->
    <a
      id="sticky-cta"
      href="#request"
      class="fixed inset-x-4 z-50 hidden rounded-full bg-forest-green py-3 px-5 text-center text-sm font-medium text-white shadow-lg transition hover:bg-[#244f3e] md:left-auto md:right-6 md:w-auto"
      style="bottom: calc(0.35rem + env(safe-area-inset-bottom));"
      aria-label="Request a consultation"
    >
      Request a consultation
    </a>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        const heroSection = document.querySelector('#hero');
        const requestSection = document.querySelector('#request');
        const stickyCta = document.querySelector('#sticky-cta');
        if (!heroSection || !stickyCta) return;

        const visibleTargets = new Set();

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                visibleTargets.add(entry.target);
              } else {
                visibleTargets.delete(entry.target);
              }
            });
            if (visibleTargets.size > 0) {
              stickyCta.classList.add('hidden');
            } else {
              stickyCta.classList.remove('hidden');
            }
          },
          { root: null, threshold: 0 }
        );

        observer.observe(heroSection);
        if (requestSection) observer.observe(requestSection);
      });
    </script>
  </body>
</html>
